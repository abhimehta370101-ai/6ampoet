# Postgres connection string (Railway provides this automatically when you add the Postgres plugin)
DATABASE_URL=postgres://user:password@localhost:5432/sixampoet

# Resend (https://resend.com) API key used to send all transactional email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# From address used for all outgoing email (must be on a domain verified in Resend)
EMAIL_FROM=6ampoet <hello@6ampoet.com>

# Public URL of the deployed app, no trailing slash (used to build magic links)
APP_URL=https://6ampoet.com

# Secret key used to sign HMAC session cookies. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Admin login credentials
ADMIN_EMAIL=you@6ampoet.com
# Generate with: npm run hash-password
ADMIN_PASSWORD_HASH=

# Cloudflare R2 (S3-compatible) credentials for the ebook PDF
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Path/key to the ebook PDF inside the R2 bucket. Leave empty until the ebook is uploaded.
EBOOK_R2_KEY=

# Number of free founding member spots
FOUNDING_CAP=100
